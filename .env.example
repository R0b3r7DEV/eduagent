# =============================================================================
# EduAgent AI — environment variables template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── LLM ───────────────────────────────────────────────────────────────────────
# Server-level fallbacks for development. In production, users supply their own keys via the UI.
ANTHROPIC_API_KEY=            # Optional dev fallback — claude-sonnet-4-6
GEMINI_API_KEY=               # Optional dev fallback — gemini-2.0-flash (free tier available at aistudio.google.com)
DEFAULT_LLM_PROVIDER=anthropic  # anthropic | gemini
COHERE_API_KEY=               # Required. Multilingual embeddings (embed-multilingual-v3.0)

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key to encrypt user Anthropic API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# All values from: Supabase Dashboard → Settings → API

# PostgreSQL connection — use the Session Pooler URI (port 5432, mode=session)
# Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=            # "anon public" key — safe to use in the browser
SUPABASE_SERVICE_ROLE_KEY=    # Secret. Never expose to the frontend.

# JWT secret for server-side token verification
# Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Storage bucket name (create it in Supabase Dashboard → Storage)
SUPABASE_STORAGE_BUCKET=documents

# Frontend public vars (same project, different key)
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Redis / Upstash ───────────────────────────────────────────────────────────
# Local:   redis://localhost:6379/0
# Upstash: rediss://default:[password]@[host]:[port]
REDIS_URL=redis://redis:6379/0

# ── Google OAuth (Google Classroom connector) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Moodle connector ──────────────────────────────────────────────────────────
MOODLE_BASE_URL=              # e.g. https://moodle.myschool.com
MOODLE_WSTOKEN=               # Moodle web service token

# ── LlamaCloud (PDF parsing) ──────────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development       # development | production
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=8

# ── Local Docker only (not used when pointing to Supabase) ───────────────────
POSTGRES_PASSWORD=password    # Used by the db container in docker-compose.yml

# ── Frontend (Vercel / local) ─────────────────────────────────────────────────
# Railway backend URL — set this in Vercel project settings
NEXT_PUBLIC_API_URL=https://your-backend.railway.app
